{
  "name": "bayraq-elarab",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"electron electron/main.cjs\"",
    "electron:build": "vite build && electron-builder",
    "cap:sync": "npx cap sync",
    "cap:android": "npx cap open android"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.16.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.12"
  },
  "build": {
    "appId": "com.bayraq.elarab",
    "productName": "بيرق العرب",
    "copyright": "© 2025 بيرق العرب للتوظيف بالخارج",
    "directories": { "output": "dist-electron" },
    "files": ["dist/**/*", "electron/**/*", "public/**/*"],
    "win": {
      "icon": "public/logo.jpg",
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "بيرق العرب"
    }
  }
}
